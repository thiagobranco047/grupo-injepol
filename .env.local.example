# Instruções:
# 1. Copie este arquivo e renomeie para: .env.local
# 2. Preencha os valores conforme sua necessidade
# 3. NUNCA commite o arquivo .env.local no Git (já está no .gitignore)

# ============================================
# SITE URL (para produção)
# ============================================
NEXT_PUBLIC_SITE_URL=https://grupoinjepol.com.br

# ============================================
# FORMULÁRIO DE CONTATO
# ============================================

# Escolha UMA das opções abaixo e comente as outras

# OPÇÃO 1: Resend (https://resend.com) - Recomendado
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=contato@grupoinjepol.com.br
# RESEND_TO_EMAIL=contato@grupoinjepol.com.br

# OPÇÃO 2: SMTP Genérico (Gmail, Outlook, etc)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu-email@gmail.com
# SMTP_PASS=sua-senha-de-app
# SMTP_FROM=seu-email@gmail.com
# SMTP_TO=contato@grupoinjepol.com.br

# OPÇÃO 3: SendGrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=contato@grupoinjepol.com.br
# SENDGRID_TO_EMAIL=contato@grupoinjepol.com.br

# OPÇÃO 4: Webhook (Zapier, Make, n8n, etc)
# WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxxx/xxxxx

# ============================================
# ANALYTICS (Opcional)
# ============================================

# Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ============================================
# BANCO DE DADOS (Se usar Prisma/ORM)
# ============================================

# PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/grupoinjepol

# MySQL
# DATABASE_URL=mysql://user:password@localhost:3306/grupoinjepol

# ============================================
# OUTRAS CONFIGURAÇÕES
# ============================================

# Ambiente (development, production, test)
NODE_ENV=development

# Porta do servidor (padrão: 3000)
# PORT=3000

# ============================================
# NOTAS IMPORTANTES
# ============================================

# GMAIL:
# Para usar Gmail, você precisa:
# 1. Ativar "Verificação em duas etapas"
# 2. Criar uma "Senha de app" (não use sua senha normal)
# 3. Usar a senha de app gerada no campo SMTP_PASS

# RESEND:
# 1. Crie conta em https://resend.com (gratuito para 3k emails/mês)
# 2. Verifique seu domínio
# 3. Copie a API key

# SENDGRID:
# 1. Crie conta em https://sendgrid.com (gratuito para 100 emails/dia)
# 2. Verifique seu domínio ou e-mail
# 3. Copie a API key

# WEBHOOK:
# 1. Crie uma automação no Zapier/Make
# 2. Use o trigger "Webhook"
# 3. Copie a URL fornecida
